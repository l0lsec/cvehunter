# === LLM API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
# Optional: enables Gemini in researcher swarm model rotation
GOOGLE_API_KEY=...
# Optional: only needed if using OpenAI models
OPENAI_API_KEY=sk-...

# === Data Source Keys ===
NVD_API_KEY=...
GITHUB_TOKEN=ghp_...

# === Cost Controls ===
# Max spend per CVE run (USD). Pipeline aborts if exceeded.
MAX_COST_PER_CVE=25.0
# Max LLM API spend per month (USD). Pipeline pauses if exceeded.
MAX_MONTHLY_SPEND=200.0

# === Infrastructure ===
DOCKER_HOST=unix:///var/run/docker.sock
ARTIFACT_DIR=./artifacts
DATABASE_URL=sqlite:///./cvehunter.db

# === Logging ===
LOG_LEVEL=INFO

# === LangSmith Observability (optional) ===
# Set to "true" to enable tracing; requires a free LangSmith account
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=cvehunter

# === Researcher Swarm ===
# Set to "false" to use single-model researcher instead of multi-model swarm
RESEARCHER_SWARM_ENABLED=true
