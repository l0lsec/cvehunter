# === LLM API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
# Optional: only needed for multi-model swarm (Phase 8)
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# === Data Source Keys ===
NVD_API_KEY=...
GITHUB_TOKEN=ghp_...

# === Cost Controls ===
# Max spend per CVE run (USD). Pipeline aborts if exceeded.
MAX_COST_PER_CVE=25.0
# Max LLM API spend per month (USD). Pipeline pauses if exceeded.
MAX_MONTHLY_SPEND=200.0

# === Infrastructure ===
DOCKER_HOST=unix:///var/run/docker.sock
ARTIFACT_DIR=./artifacts
DATABASE_URL=sqlite:///./moak.db
