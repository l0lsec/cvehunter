# === LLM API Keys ===
# Anthropic is the ONLY required key — all model tiers default to Anthropic
# (Haiku 4.5 / Sonnet 4.6 / Opus 4.8).
ANTHROPIC_API_KEY=sk-ant-...
# Optional: only needed if you remap a tier to DeepSeek in config.py
DEEPSEEK_API_KEY=sk-...
# Optional: only needed if you remap a tier to Gemini in config.py
GOOGLE_API_KEY=...
# Optional: only needed if you remap a tier to OpenAI in config.py
OPENAI_API_KEY=sk-...

# === Data Source Keys ===
NVD_API_KEY=...
GITHUB_TOKEN=ghp_...

# === Cost Controls ===
# Max spend per CVE run (USD). Pipeline aborts if exceeded.
MAX_COST_PER_CVE=25.0
# Max LLM API spend per month (USD). Pipeline pauses if exceeded.
MAX_MONTHLY_SPEND=200.0

# === Infrastructure ===
DOCKER_HOST=unix:///var/run/docker.sock
ARTIFACT_DIR=./artifacts
DATABASE_URL=sqlite:///./cvehunter.db
# Abort a build if the lab network is not internet-isolated (egress reachable).
# compose_up forces internal: true on project networks, so this normally passes;
# set to false to downgrade an isolation failure to a non-fatal warning.
NETWORK_ISOLATION_ENFORCED=true

# === API ===
# Optional: when set, the /api/v1/* REST endpoints require this key via the
# X-API-Key header. The web dashboard works regardless (it calls run logic
# server-side). Leave empty to disable REST auth (local/dev).
CVEHUNTER_API_KEY=
# Comma-separated allowed CORS origins for the API.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# === Logging ===
LOG_LEVEL=INFO

# === LangSmith Observability (optional) ===
# Set to "true" to enable tracing; requires a free LangSmith account
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=cvehunter

# === Researcher Swarm ===
# Set to "false" to use single-model researcher instead of multi-model swarm
RESEARCHER_SWARM_ENABLED=true

# === Per-agent model tier overrides (optional) ===
# Override an agent's tier with <AGENT>_MODEL_TIER = cheap | smart | heavy.
# The builder is the most fidelity-sensitive agent (building a correctly
# versioned + misconfigured vulnerable lab is hard for the cheap tier), so
# escalating it is a common, cost-effective tweak:
# BUILDER_MODEL_TIER=smart
# COLLECTOR_MODEL_TIER=cheap
# JUDGE_MODEL_TIER=cheap
